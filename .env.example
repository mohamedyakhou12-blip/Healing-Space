# ═══════════════════════════════════════════════════════════════════════════════
# Healing Space — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in the values.
# All NEXT_PUBLIC_* variables are exposed to the browser.
# Non-public variables are server-only.

# ─── Firebase Configuration (Client + Server) ────────────────────────────────
# These are public-facing and NOT secrets. Firebase security is handled via
# Firebase Console rules (Firestore Rules, Storage Rules, etc.), not by obscurity.
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyC0dHZ4Z1AkVeMlo21Y2e5MHF6hJkG6E48
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=healing-space-5a76f.firebaseapp.com
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://healing-space-5a76f-default-rtdb.firebaseio.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=healing-space-5a76f
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=healing-space-5a76f.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=873540723647
NEXT_PUBLIC_FIREBASE_APP_ID=1:873540723647:web:e78a1edbe4fc249e61370a

# ─── Firebase Admin SDK (Server Only) ────────────────────────────────────────
# REQUIRED for Firestore operations. Get from Firebase Console → Project Settings → Service Accounts
# Can be raw JSON or base64-encoded JSON
FIREBASE_SERVICE_ACCOUNT_KEY=

# ─── Session Secret (Server Only) ────────────────────────────────────────────
# REQUIRED in production! Used to encrypt iron-session cookies.
# Generate with: openssl rand -base64 32
# Must be at least 32 characters.
SESSION_SECRET=

# ─── Cloudinary Configuration ────────────────────────────────────────────────
# Used for file uploads (images, videos, audio, PDFs, receipts)
# Get from Cloudinary Dashboard: https://console.cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Google OAuth (Optional — Currently On Hold) ─────────────────────────────
# Set these in your Vercel dashboard if you want Google Sign-In
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Google Search Console Verification (Optional) ───────────────────────────
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ─── Admin Access Code ───────────────────────────────────────────────────────
# The initial admin code is set via /api/setup (development only).
# In production, it's stored in Firestore siteSettings collection.
# Default admin code: 052307
# Change via Admin Panel → Settings → Change Admin Code
